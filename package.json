{
  "name": "sf-org-manager",
  "displayName": "Salesforce Org Manager",
  "description": "Manage your authorized Salesforce orgs from a dedicated VS Code Activity Bar view",
  "version": "0.0.2",
  "publisher": "JanStaniszewski",
  "license": "MIT",
  "private": true,
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/JanStaniszewski/salesforce-org-extension.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": [
    "salesforce",
    "sfdx",
    "sf cli",
    "org management",
    "apex",
    "trailhead",
    "devhub",
    "sandbox",
    "scratch org"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sfOrgManager",
          "title": "Salesforce Orgs",
          "icon": "resources/org-icon.svg"
        }
      ]
    },
    "views": {
      "sfOrgManager": [
        {
          "id": "sfOrgManagerView",
          "name": "Orgs"
        }
      ]
    },
    "commands": [
      { "command": "sfOrgManager.authorizeOrg", "title": "Authorize New Org", "category": "Salesforce Org Manager", "icon": "$(add)" },
      { "command": "sfOrgManager.refresh", "title": "Refresh", "category": "Salesforce Org Manager", "icon": "$(refresh)" },
      { "command": "sfOrgManager.toggleGroupMode", "title": "Toggle Group Mode", "category": "Salesforce Org Manager", "icon": "$(list-tree)" },
      { "command": "sfOrgManager.filterByCategory", "title": "Filter by Category", "category": "Salesforce Org Manager", "icon": "$(filter)" },
      { "command": "sfOrgManager.clearCategoryFilter", "title": "Clear Category Filter", "category": "Salesforce Org Manager", "icon": "$(clear-all)" },
      { "command": "sfOrgManager.setDefault", "title": "Set as Default Org", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.openInBrowser", "title": "Open in Browser", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.logout", "title": "Logout", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.refreshToken", "title": "Refresh Token", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.copyAuthUrl", "title": "Copy Auth URL", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.assignCategory", "title": "Assign to Project/Category", "category": "Salesforce Org Manager" },
      { "command": "sfOrgManager.removeCategory", "title": "Remove from Category", "category": "Salesforce Org Manager" }
    ],
    "menus": {
      "view/title": [
        { "command": "sfOrgManager.authorizeOrg", "when": "view == sfOrgManagerView", "group": "navigation@1" },
        { "command": "sfOrgManager.refresh", "when": "view == sfOrgManagerView", "group": "navigation@2" },
        { "command": "sfOrgManager.toggleGroupMode", "when": "view == sfOrgManagerView", "group": "navigation@3" },
        { "command": "sfOrgManager.filterByCategory", "when": "view == sfOrgManagerView", "group": "navigation@4" },
        { "command": "sfOrgManager.clearCategoryFilter", "when": "view == sfOrgManagerView", "group": "navigation@5" }
      ],
      "view/item/context": [
        { "command": "sfOrgManager.setDefault", "when": "view == sfOrgManagerView && viewItem == org" },
        { "command": "sfOrgManager.openInBrowser", "when": "view == sfOrgManagerView && viewItem == org" },
        { "command": "sfOrgManager.assignCategory", "when": "view == sfOrgManagerView && viewItem == org" },
        { "command": "sfOrgManager.removeCategory", "when": "view == sfOrgManagerView && viewItem == org" },
        { "command": "sfOrgManager.logout", "when": "view == sfOrgManagerView && viewItem == org" },
        { "command": "sfOrgManager.copyAuthUrl", "when": "view == sfOrgManagerView && viewItem == org" }
      ]
    }
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "vscode:prepublish": "npm run package",
    "test:unit": "mocha",
    "pretest:integration": "tsc -p ./test/tsconfig.json",
    "test:integration": "npm run pretest:integration && node ./out/test/runTest.js",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.20.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
